// ── NodeBuilder ──────────────────────────────────────────────────────

NodeBuilder::NodeBuilder()
    : m_handle { iox2_node_builder_new(nullptr) } {
}

template <ServiceType T>
auto NodeBuilder::create() const&& -> iox::expected<Node<T>, NodeCreationFailure> {
    iox2_node_h handle = nullptr;
    auto result = iox2_node_builder_create(
        m_handle, nullptr,
        static_cast<iox2_service_type_e>(static_cast<int>(T)),
        &handle);
    if (result == IOX2_OK) {
        return iox::ok(Node<T>(handle));
    }
    return iox::err(iox::into<NodeCreationFailure>(result));
}

template auto NodeBuilder::create<ServiceType::Ipc>() const&&
    -> iox::expected<Node<ServiceType::Ipc>, NodeCreationFailure>;
template auto NodeBuilder::create<ServiceType::Local>() const&&
    -> iox::expected<Node<ServiceType::Local>, NodeCreationFailure>;

// ── Node<T> ──────────────────────────────────────────────────────────

template <ServiceType T>
Node<T>::Node(iox2_node_h handle)
    : m_handle { handle } {
}

template <ServiceType T>
Node<T>::Node(Node&& rhs) noexcept
    : m_handle { rhs.m_handle } {
    rhs.m_handle = nullptr;
}

template <ServiceType T>
auto Node<T>::operator=(Node&& rhs) noexcept -> Node& {
    if (this != &rhs) {
        drop();
        m_handle = rhs.m_handle;
        rhs.m_handle = nullptr;
    }
    return *this;
}

template <ServiceType T>
Node<T>::~Node() {
    drop();
}

template <ServiceType T>
void Node<T>::drop() {
    if (m_handle != nullptr) {
        iox2_node_drop(m_handle);
        m_handle = nullptr;
    }
}

template <ServiceType T>
auto Node<T>::service_builder(const ServiceName& name) const -> ServiceBuilder<T> {
    return ServiceBuilder<T>(&m_handle, name.as_view().m_ptr);
}

template <ServiceType T>
auto Node<T>::config() const -> ConfigView {
    return ConfigView(nullptr);
}

