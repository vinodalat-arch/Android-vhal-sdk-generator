int MockTransport::receivePdu(uint32_t& pdu_id_out, uint8_t* data, size_t max_len) {
    std::unique_lock<std::mutex> lock(mQueueMutex);
    if (mRxQueue.empty()) {
        // Wait up to 200ms for the generator to produce data.
        mQueueCv.wait_for(lock, std::chrono::milliseconds(200),
                          [this] { return !mRxQueue.empty() || !mRunning; });
    }
    if (mRxQueue.empty()) {
        return 0;
    }

    PduPacket pkt = std::move(mRxQueue.front());
    mRxQueue.pop();
    lock.unlock();

    pdu_id_out = pkt.pdu_id;
    size_t copyLen = std::min(pkt.data.size(), max_len);
    memcpy(data, pkt.data.data(), copyLen);
    return static_cast<int>(copyLen);
}

// ---------------------------------------------------------------------------
// Bit packing helper
// ---------------------------------------------------------------------------

void MockTransport::packSignalIntoPdu(std::vector<uint8_t>& pduBuf,
                                       uint32_t startBit, uint32_t bitLen,
                                       uint32_t value) {
    for (uint32_t i = 0; i < bitLen; ++i) {
        uint32_t bitPos = startBit + i;
        uint32_t byteIdx = bitPos / 8;
        uint32_t bitIdx = bitPos % 8;
        if (byteIdx < pduBuf.size()) {
            if (value & (1u << i)) {
                pduBuf[byteIdx] |= (1u << bitIdx);
            } else {
                pduBuf[byteIdx] &= ~(1u << bitIdx);
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Generator loop -- produces cycling test values every 1 second
// ---------------------------------------------------------------------------

void MockTransport::generatorLoop() {
    LOG(INFO) << LOG_TAG << ": Generator thread started";

    while (mRunning) {
        std::this_thread::sleep_for(std::chrono::seconds(1));
        if (!mRunning) break;

        mCycleCounter++;

        // Group signals by PDU ID so we build one PDU buffer per PDU.
        std::map<uint32_t, std::vector<const MockSignalDef*>> pduSignals;
        for (size_t i = 0; i < kMockRxSignalCount; ++i) {
            pduSignals[kMockRxSignals[i].pdu_id].push_back(&kMockRxSignals[i]);
        }

        for (auto& [pduId, signals] : pduSignals) {
            // Determine PDU length: max byte needed by any signal.
            uint32_t maxByte = 0;
            for (const auto* sig : signals) {
                uint32_t endByte = (sig->start_bit + sig->bit_length + 7) / 8;
                if (endByte > maxByte) maxByte = endByte;
            }

            std::vector<uint8_t> pduBuf(maxByte, 0);

            for (const auto* sig : signals) {
                // Generate a cycling value that stays within bitmask range.
                uint32_t maxVal = sig->bitmask;
                uint32_t testVal = 0;
                if (maxVal > 0) {
                    testVal = mCycleCounter % (maxVal + 1);
                }

                packSignalIntoPdu(pduBuf, sig->start_bit, sig->bit_length, testVal);

                LOG(DEBUG) << LOG_TAG << ": Mock RX " << sig->signal_name
                           << " = " << testVal << " (cycle " << mCycleCounter << ")";
            }

            // Enqueue the PDU.
            {
                std::lock_guard<std::mutex> lock(mQueueMutex);
                mRxQueue.push({pduId, std::move(pduBuf)});
            }
            mQueueCv.notify_one();
        }

        LOG(INFO) << LOG_TAG << ": Generated mock cycle " << mCycleCounter;
    }

    LOG(INFO) << LOG_TAG << ": Generator thread exited";
}

