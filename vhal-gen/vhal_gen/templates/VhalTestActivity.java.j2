            else if (propType == TYPE_FLOAT)
                mPropertyManager.setProperty(Float.class, propId, areaId, (Float) value);
            else
                mPropertyManager.setProperty(Integer.class, propId, areaId, (Integer) value);
            Toast.makeText(this, "Sent!", Toast.LENGTH_SHORT).show();
        } catch (Exception e) {
            Toast.makeText(this, "Error: " + e.getMessage(), Toast.LENGTH_LONG).show();
        }
    }

