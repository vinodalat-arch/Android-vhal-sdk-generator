                String valueStr;

                if (propType == TYPE_FLOAT) {
                    CarPropertyValue<Float> val =
                            mPropertyManager.getProperty(Float.class, propId, areaId);
                    if (val != null && val.getStatus() == CarPropertyValue.STATUS_AVAILABLE) {
                        valueStr = String.valueOf(val.getValue());
                    } else {
                        valueStr = "(unavailable)";
                    }
                } else if (propType == TYPE_BOOLEAN) {
                    CarPropertyValue<Boolean> val =
                            mPropertyManager.getProperty(Boolean.class, propId, areaId);
                    if (val != null && val.getStatus() == CarPropertyValue.STATUS_AVAILABLE) {
                        valueStr = String.valueOf(val.getValue());
                    } else {
                        valueStr = "(unavailable)";
                    }
                } else if (propType == TYPE_INT64) {
                    CarPropertyValue<Long> val =
                            mPropertyManager.getProperty(Long.class, propId, areaId);
                    if (val != null && val.getStatus() == CarPropertyValue.STATUS_AVAILABLE) {
                        valueStr = String.valueOf(val.getValue());
                    } else {
                        valueStr = "(unavailable)";
                    }
                } else {
                    // Default: INT32
                    CarPropertyValue<Integer> val =
                            mPropertyManager.getProperty(Integer.class, propId, areaId);
                    if (val != null && val.getStatus() == CarPropertyValue.STATUS_AVAILABLE) {
                        valueStr = String.valueOf(val.getValue());
                    } else {
                        valueStr = "(unavailable)";
                    }
                }

                mTable.addView(createResultRow(name, type, "OK", valueStr, true));
                passed++;
                Log.i(TAG, name + " = " + valueStr);

            } catch (Exception e) {
                mTable.addView(createResultRow(name, type, "FAIL", e.getMessage(), false));
                failed++;
                Log.e(TAG, "Failed to read " + name, e);
            }
        }

        // Summary row
        addSummaryRow(passed, failed);
    }

