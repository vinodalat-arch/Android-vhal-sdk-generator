/*
 * BridgeVehicleHardware implementation.
 * Bridges AOSP VHAL to VehicleDaemon over a socketpair.
 * The daemon is spawned as a child process via fork()+exec().
 * DO NOT EDIT -- generated by vhal-gen.
 */

#include "BridgeVehicleHardware.h"

#include <android-base/logging.h>
#include <json/json.h>
#include <sys/prctl.h>
#include <sys/socket.h>
#include <sys/wait.h>
#include <signal.h>
#include <unistd.h>

#include <cerrno>
#include <chrono>
#include <cstring>
#include <fstream>
#include <sstream>
#include <thread>

#define LOG_TAG "BridgeVHAL"

namespace android::hardware::automotive::vehicle::bridge {

using namespace ::vehicle;

// ---------------------------------------------------------------------------
// Construction / destruction
// ---------------------------------------------------------------------------

BridgeVehicleHardware::BridgeVehicleHardware() {
    LOG(INFO) << LOG_TAG << ": Initializing BridgeVehicleHardware";

    // Try primary path, fall back to alternate AOSP config directory.
    static const char* kConfigPaths[] = {
        "{{ config_json_path }}",
        "/vendor/etc/automotive/vhalconfig/DefaultProperties.json",
    };
    for (const auto* path : kConfigPaths) {
        std::ifstream probe(path);
        if (probe.good()) {
            loadPropertyConfigs(path);
            break;
        }
    }

    spawnDaemon();
}

BridgeVehicleHardware::~BridgeVehicleHardware() {
    mRunning = false;
    killDaemon();
    if (mRxThread.joinable()) {
        mRxThread.join();
    }
    if (mWatchdogThread.joinable()) {
        mWatchdogThread.join();
    }
    if (mClientFd >= 0) {
        close(mClientFd);
    }
    LOG(INFO) << LOG_TAG << ": BridgeVehicleHardware destroyed";
}

// ---------------------------------------------------------------------------
// Config loading (DefaultProperties.json)
// ---------------------------------------------------------------------------

void BridgeVehicleHardware::loadPropertyConfigs(const std::string& configPath) {
    std::ifstream ifs(configPath);
    if (!ifs.is_open()) {
        LOG(ERROR) << LOG_TAG << ": Cannot open config file: " << configPath;
        return;
    }

    Json::Value root;
    Json::CharReaderBuilder builder;
    std::string errs;
    if (!Json::parseFromStream(builder, ifs, &root, &errs)) {
        LOG(ERROR) << LOG_TAG << ": Failed to parse config JSON: " << errs;
        return;
    }

    // Support both AOSP format {"apiVersion":1, "properties":[...]}
    // and flat array [...] format.
    const Json::Value& entries = root.isObject() && root.isMember("properties")
            ? root["properties"] : root;

    for (const auto& entry : entries) {
        VehiclePropConfig config{};
        // The property field is either "VehicleProperty::NAME" or a hex string.
        std::string propStr = entry["property"].asString();
        if (propStr.rfind("0x", 0) == 0) {
            config.prop = static_cast<int32_t>(std::stoul(propStr, nullptr, 16));
        } else if (propStr.find("::") != std::string::npos) {
            // Standard property -- the numeric ID is already embedded as hex
            // in the property field (e.g., "VehicleProperty::HEADLIGHTS_SWITCH").
            // We resolve it from our compiled-in AIDL constants.
            // For now, attempt hex parse of the suffix; at runtime the AIDL
            // generated constant is used via the switch below.
            std::string name = propStr.substr(propStr.find("::") + 2);
            // The JSON also carries a numeric "propertyId" field for reliable parsing.
            if (entry.isMember("propertyId")) {
                config.prop = entry["propertyId"].asInt();
            } else {
                LOG(WARNING) << LOG_TAG << ": Cannot resolve " << propStr
                             << " without propertyId field, skipping";
                continue;
            }
        } else {
            config.prop = static_cast<int32_t>(std::stoul(propStr, nullptr, 0));
        }

        // Access -- use AIDL enum types
        if (entry.isMember("access")) {
            std::string accessStr = entry["access"].asString();
            if (accessStr.find("READ_WRITE") != std::string::npos) {
                config.access = VehiclePropertyAccess::READ_WRITE;
            } else if (accessStr.find("WRITE") != std::string::npos) {
                config.access = VehiclePropertyAccess::WRITE;
            } else {
                config.access = VehiclePropertyAccess::READ;
            }
        } else {
            config.access = VehiclePropertyAccess::READ;
        }

        // Change mode -- use AIDL enum types
        if (entry.isMember("changeMode")) {
            std::string cmStr = entry["changeMode"].asString();
            if (cmStr.find("CONTINUOUS") != std::string::npos) {
                config.changeMode = VehiclePropertyChangeMode::CONTINUOUS;
            } else if (cmStr.find("ON_CHANGE") != std::string::npos) {
                config.changeMode = VehiclePropertyChangeMode::ON_CHANGE;
            } else {
                config.changeMode = VehiclePropertyChangeMode::STATIC;
            }
        } else {
            config.changeMode = VehiclePropertyChangeMode::ON_CHANGE;
        }

        // Area configs
        if (entry.isMember("areas")) {
            for (const auto& area : entry["areas"]) {
                VehicleAreaConfig ac{};
                ac.areaId = area["areaId"].asInt();
                if (area.isMember("minInt32Value")) {
                    ac.minInt32Value = static_cast<int32_t>(area["minInt32Value"].asInt64());
                    ac.maxInt32Value = static_cast<int32_t>(area["maxInt32Value"].asInt64());
                }
                if (area.isMember("minFloatValue")) {
                    ac.minFloatValue = area["minFloatValue"].asFloat();
                    ac.maxFloatValue = area["maxFloatValue"].asFloat();
                }
                config.areaConfigs.push_back(ac);
            }
        } else {
            // Default: single global area
            VehicleAreaConfig ac{};
            ac.areaId = 0;
            config.areaConfigs.push_back(ac);
        }

        // Sample rate for CONTINUOUS properties
        if (entry.isMember("maxSampleRate")) {
            config.maxSampleRate = entry["maxSampleRate"].asFloat();
        }
        if (entry.isMember("minSampleRate")) {
            config.minSampleRate = entry["minSampleRate"].asFloat();
        }

        mConfigs.push_back(config);
        LOG(INFO) << LOG_TAG << ": Loaded property config prop=0x" << std::hex << config.prop;
    }

    LOG(INFO) << LOG_TAG << ": Loaded " << std::dec << mConfigs.size() << " property configs";
}

// ---------------------------------------------------------------------------
// Daemon lifecycle (socketpair + fork + exec)
// ---------------------------------------------------------------------------

void BridgeVehicleHardware::spawnDaemon() {
    std::lock_guard<std::mutex> lock(mSpawnMutex);

    int fds[2];
    if (socketpair(AF_UNIX, SOCK_STREAM, 0, fds) < 0) {
        LOG(ERROR) << LOG_TAG << ": socketpair() failed: " << strerror(errno);
        return;
    }

    pid_t pid = fork();
    if (pid < 0) {
        LOG(ERROR) << LOG_TAG << ": fork() failed: " << strerror(errno);
        close(fds[0]);
        close(fds[1]);
        return;
    }

    if (pid == 0) {
        // ── Child process ──
        // Auto-kill child when parent (VHAL) dies.
        prctl(PR_SET_PDEATHSIG, SIGKILL);

        // Wire the child's end of the socketpair to STDIN.
        dup2(fds[1], STDIN_FILENO);
        close(fds[0]);
        close(fds[1]);

        execl(kDaemonPath, kDaemonPath, nullptr);
        // execl only returns on failure.
        _exit(127);
    }

    // ── Parent process ──
    close(fds[1]);
    mClientFd = fds[0];
    mDaemonPid = pid;

    LOG(INFO) << LOG_TAG << ": Spawned daemon pid=" << pid << " (fd=" << mClientFd << ")";

    mRunning = true;
    // Only create threads if they are not already running.  When called from
    // watchdogLoop() during respawn, the watchdog thread is already active and
    // the rx thread was joined before this call — so only the rx thread is
    // recreated.  Assigning to a joinable std::thread calls std::terminate().
    if (!mRxThread.joinable()) {
        mRxThread = std::thread(&BridgeVehicleHardware::rxThreadLoop, this);
    }
    if (!mWatchdogThread.joinable()) {
        mWatchdogThread = std::thread(&BridgeVehicleHardware::watchdogLoop, this);
    }
}

void BridgeVehicleHardware::killDaemon() {
    std::lock_guard<std::mutex> lock(mSpawnMutex);
    if (mDaemonPid > 0) {
        kill(mDaemonPid, SIGTERM);
        int status;
        waitpid(mDaemonPid, &status, 0);
        LOG(INFO) << LOG_TAG << ": Daemon pid=" << mDaemonPid << " terminated";
        mDaemonPid = -1;
    }
}

void BridgeVehicleHardware::watchdogLoop() {
    LOG(INFO) << LOG_TAG << ": Watchdog thread started";
    while (mRunning) {
        if (mDaemonPid <= 0) {
            std::this_thread::sleep_for(std::chrono::milliseconds(500));
            continue;
        }

        int status;
        pid_t result = waitpid(mDaemonPid, &status, WNOHANG);
        if (result == mDaemonPid) {
            LOG(WARNING) << LOG_TAG << ": Daemon exited (status=" << status << ")";

            // Close the dead socket.
            {
                std::lock_guard<std::mutex> lock(mSocketMutex);
                if (mClientFd >= 0) {
                    close(mClientFd);
                    mClientFd = -1;
                }
            }
            mDaemonPid = -1;

            if (mRespawnCount >= kMaxRespawns) {
                LOG(ERROR) << LOG_TAG << ": Max respawn limit (" << kMaxRespawns
                           << ") reached, giving up";
                mRunning = false;
                break;
            }

            ++mRespawnCount;
            LOG(INFO) << LOG_TAG << ": Respawning daemon (attempt " << mRespawnCount << ")";

            // Wait before RX thread notices disconnect, then respawn.
            if (mRxThread.joinable()) {
                mRxThread.join();
            }

            // Re-spawn (spawnDaemon acquires mSpawnMutex, but watchdog does not hold it here).
            spawnDaemon();
        }

        std::this_thread::sleep_for(std::chrono::milliseconds(500));
    }
    LOG(INFO) << LOG_TAG << ": Watchdog thread exited";
}

// ---------------------------------------------------------------------------
// IPC send / receive helpers
// ---------------------------------------------------------------------------

bool BridgeVehicleHardware::sendIpcMessage(const IpcMessage* msg, size_t totalLen) const {
    std::lock_guard<std::mutex> lock(mSocketMutex);
    if (mClientFd < 0) return false;

    ssize_t sent = 0;
    const uint8_t* ptr = reinterpret_cast<const uint8_t*>(msg);
    while (sent < static_cast<ssize_t>(totalLen)) {
        ssize_t n = write(mClientFd, ptr + sent, totalLen - sent);
        if (n <= 0) {
            LOG(ERROR) << LOG_TAG << ": write() failed: " << strerror(errno);
            return false;
        }
        sent += n;
    }
    return true;
}

bool BridgeVehicleHardware::recvIpcMessage(std::vector<uint8_t>& buffer) const {
    // First read the header.
    buffer.resize(IPC_HEADER_SIZE);
    ssize_t nread = 0;
    while (nread < static_cast<ssize_t>(IPC_HEADER_SIZE)) {
        ssize_t n = read(mClientFd, buffer.data() + nread, IPC_HEADER_SIZE - nread);
        if (n <= 0) {
            if (n == 0) {
                LOG(WARNING) << LOG_TAG << ": Daemon disconnected";
            } else {
                LOG(ERROR) << LOG_TAG << ": read() header failed: " << strerror(errno);
            }
            return false;
        }
        nread += n;
    }

    const auto* hdr = reinterpret_cast<const IpcMessage*>(buffer.data());
    uint32_t valueLen = hdr->value_len;
    static constexpr uint32_t kMaxPayload = 64 * 1024;  // 64 KB sanity limit
    if (valueLen > kMaxPayload) {
        LOG(ERROR) << LOG_TAG << ": IPC payload too large: " << valueLen;
        return false;
    }
    if (valueLen > 0) {
        buffer.resize(IPC_HEADER_SIZE + valueLen);
        nread = 0;
        while (nread < static_cast<ssize_t>(valueLen)) {
            ssize_t n = read(mClientFd, buffer.data() + IPC_HEADER_SIZE + nread,
                             valueLen - nread);
            if (n <= 0) {
                LOG(ERROR) << LOG_TAG << ": read() payload failed: " << strerror(errno);
                return false;
            }
            nread += n;
        }
    }

    return true;
}

// ---------------------------------------------------------------------------
// RX thread -- reads PROPERTY_CHANGED messages from daemon
// ---------------------------------------------------------------------------

void BridgeVehicleHardware::rxThreadLoop() {
    LOG(INFO) << LOG_TAG << ": RX thread started";
    while (mRunning) {
        std::vector<uint8_t> buffer;
        if (!recvIpcMessage(buffer)) {
            LOG(WARNING) << LOG_TAG << ": RX thread: connection lost, exiting";
            break;
        }

        const auto* msg = reinterpret_cast<const IpcMessage*>(buffer.data());
        if (msg->msg_type == IpcMsgType::PROPERTY_CHANGED) {
            handlePropertyChanged(msg, buffer.size());
        } else if (msg->msg_type == IpcMsgType::PROPERTY_RESPONSE) {
            // Responses to GET requests are handled inline (see getValues).
            // This branch is a safety net for unexpected async responses.
            LOG(WARNING) << LOG_TAG << ": Unexpected PROPERTY_RESPONSE on RX thread";
        }
    }
    LOG(INFO) << LOG_TAG << ": RX thread exited";
}

void BridgeVehicleHardware::handlePropertyChanged(const IpcMessage* msg, size_t /*totalLen*/) {
    VehiclePropValue propValue{};
    propValue.prop = msg->property_id;
    propValue.areaId = msg->area_id;
    propValue.timestamp = std::chrono::duration_cast<std::chrono::nanoseconds>(
            std::chrono::steady_clock::now().time_since_epoch()).count();

    if (msg->value_type == IpcValueType::INT32 && msg->value_len >= sizeof(int32_t)) {
        int32_t val;
        memcpy(&val, msg->value, sizeof(int32_t));
        propValue.value.int32Values = {val};
    } else if (msg->value_type == IpcValueType::FLOAT && msg->value_len >= sizeof(float)) {
        float val;
        memcpy(&val, msg->value, sizeof(float));
        propValue.value.floatValues = {val};
    } else if (msg->value_type == IpcValueType::BOOLEAN && msg->value_len >= sizeof(int32_t)) {
        int32_t val;
        memcpy(&val, msg->value, sizeof(int32_t));
        propValue.value.int32Values = {val};
    } else if (msg->value_type == IpcValueType::INT64 && msg->value_len >= sizeof(int64_t)) {
        int64_t val;
        memcpy(&val, msg->value, sizeof(int64_t));
        propValue.value.int64Values = {val};
    }

    // Update local cache.
    {
        std::lock_guard<std::mutex> lock(mValueMutex);
        mValueStore[{msg->property_id, msg->area_id}] = propValue;
    }

    // Notify the VHAL framework.
    if (mOnPropertyChangeCallback) {
        std::vector<VehiclePropValue> values = {propValue};
        (*mOnPropertyChangeCallback)(values);
    }
}

// ---------------------------------------------------------------------------
// IVehicleHardware implementation
// ---------------------------------------------------------------------------

std::vector<VehiclePropConfig> BridgeVehicleHardware::getAllPropertyConfigs() const {
    return mConfigs;
}

StatusCode BridgeVehicleHardware::getValues(
        std::shared_ptr<const GetValuesCallback> callback,
        const std::vector<GetValueRequest>& requests) const {
    std::vector<GetValueResult> results;

    for (const auto& req : requests) {
        GetValueResult result{};
        result.requestId = req.requestId;

        // Check local cache first.
        {
            std::lock_guard<std::mutex> lock(mValueMutex);
            auto it = mValueStore.find({req.prop.prop, req.prop.areaId});
            if (it != mValueStore.end()) {
                result.status = StatusCode::OK;
                result.prop = it->second;
                results.push_back(result);
                continue;
            }
        }

        // Build and send GET_PROPERTY IPC message.
        std::vector<uint8_t> buf(IPC_HEADER_SIZE);
        auto* msg = reinterpret_cast<IpcMessage*>(buf.data());
        msg->msg_type = IpcMsgType::GET_PROPERTY;
        msg->property_id = req.prop.prop;
        msg->area_id = req.prop.areaId;
        msg->value_type = IpcValueType::INT32;
        msg->value_len = 0;

        if (!sendIpcMessage(msg, IPC_HEADER_SIZE)) {
            result.status = StatusCode::INTERNAL_ERROR;
            results.push_back(result);
            continue;
        }

        // Wait for PROPERTY_RESPONSE (synchronous for simplicity).
        std::vector<uint8_t> respBuf;
        if (!recvIpcMessage(respBuf)) {
            result.status = StatusCode::INTERNAL_ERROR;
            results.push_back(result);
            continue;
        }

        const auto* resp = reinterpret_cast<const IpcMessage*>(respBuf.data());
        if (resp->msg_type != IpcMsgType::PROPERTY_RESPONSE) {
            result.status = StatusCode::INTERNAL_ERROR;
            results.push_back(result);
            continue;
        }

        VehiclePropValue propValue{};
        propValue.prop = resp->property_id;
        propValue.areaId = resp->area_id;
        propValue.timestamp = std::chrono::duration_cast<std::chrono::nanoseconds>(
                std::chrono::steady_clock::now().time_since_epoch()).count();

        if (resp->value_type == IpcValueType::INT32 && resp->value_len >= sizeof(int32_t)) {
            int32_t val;
            memcpy(&val, resp->value, sizeof(int32_t));
            propValue.value.int32Values = {val};
        } else if (resp->value_type == IpcValueType::FLOAT && resp->value_len >= sizeof(float)) {
            float val;
            memcpy(&val, resp->value, sizeof(float));
            propValue.value.floatValues = {val};
        } else if (resp->value_type == IpcValueType::BOOLEAN && resp->value_len >= sizeof(int32_t)) {
            int32_t val;
            memcpy(&val, resp->value, sizeof(int32_t));
            propValue.value.int32Values = {val};
        } else if (resp->value_type == IpcValueType::INT64 && resp->value_len >= sizeof(int64_t)) {
            int64_t val;
            memcpy(&val, resp->value, sizeof(int64_t));
            propValue.value.int64Values = {val};
        }

        result.status = StatusCode::OK;
        result.prop = propValue;
        results.push_back(result);
    }

    (*callback)(results);
    return StatusCode::OK;
}

StatusCode BridgeVehicleHardware::setValues(
        std::shared_ptr<const SetValuesCallback> callback,
        const std::vector<SetValueRequest>& requests) {
    std::vector<SetValueResult> results;

    for (const auto& req : requests) {
        SetValueResult result{};
        result.requestId = req.requestId;

        // Determine value type and payload.
        IpcValueType vtype = IpcValueType::INT32;
        std::vector<uint8_t> payload;

        if (!req.value.value.floatValues.empty()) {
            vtype = IpcValueType::FLOAT;
            float val = req.value.value.floatValues[0];
            payload.resize(sizeof(float));
            memcpy(payload.data(), &val, sizeof(float));
        } else if (!req.value.value.int64Values.empty()) {
            vtype = IpcValueType::INT64;
            int64_t val = req.value.value.int64Values[0];
            payload.resize(sizeof(int64_t));
            memcpy(payload.data(), &val, sizeof(int64_t));
        } else if (!req.value.value.int32Values.empty()) {
            vtype = IpcValueType::INT32;
            int32_t val = req.value.value.int32Values[0];
            payload.resize(sizeof(int32_t));
            memcpy(payload.data(), &val, sizeof(int32_t));
        }

        size_t totalLen = IPC_HEADER_SIZE + payload.size();
        std::vector<uint8_t> buf(totalLen);
        auto* msg = reinterpret_cast<IpcMessage*>(buf.data());
        msg->msg_type = IpcMsgType::SET_PROPERTY;
        msg->property_id = req.value.prop;
        msg->area_id = req.value.areaId;
        msg->value_type = vtype;
        msg->value_len = static_cast<uint32_t>(payload.size());
        if (!payload.empty()) {
            memcpy(msg->value, payload.data(), payload.size());
        }

        if (sendIpcMessage(msg, totalLen)) {
            result.status = StatusCode::OK;
        } else {
            result.status = StatusCode::INTERNAL_ERROR;
        }
        results.push_back(result);
    }

    (*callback)(results);
    return StatusCode::OK;
}

DumpResult BridgeVehicleHardware::dump(const std::vector<std::string>& /* options */) {
    DumpResult dr{};
    dr.callerShouldDumpState = true;
    std::ostringstream oss;
    oss << "BridgeVehicleHardware status:" << std::endl;
    oss << "  Configs loaded: " << mConfigs.size() << std::endl;
    oss << "  Daemon connected: " << (mClientFd >= 0 ? "yes" : "no") << std::endl;
    oss << "  Daemon pid: " << mDaemonPid << std::endl;
    oss << "  Respawn count: " << mRespawnCount << std::endl;
    oss << "  Cached values: " << mValueStore.size() << std::endl;
    dr.buffer = oss.str();
    return dr;
}

StatusCode BridgeVehicleHardware::checkHealth() {
    return (mClientFd >= 0 && mRunning) ? StatusCode::OK : StatusCode::INTERNAL_ERROR;
}

void BridgeVehicleHardware::registerOnPropertyChangeEvent(
        std::unique_ptr<const PropertyChangeCallback> callback) {
    mOnPropertyChangeCallback = std::move(callback);
}

void BridgeVehicleHardware::registerOnPropertySetErrorEvent(
        std::unique_ptr<const PropertySetErrorCallback> callback) {
    mOnPropertySetErrorCallback = std::move(callback);
}

StatusCode BridgeVehicleHardware::updateSampleRate(
        int32_t /* propId */, int32_t /* areaId */, float /* sampleRate */) {
    // All RX properties are pushed by the daemon at the transport's native rate.
    // Sample rate control is not yet forwarded to the daemon.
    return StatusCode::OK;
}

