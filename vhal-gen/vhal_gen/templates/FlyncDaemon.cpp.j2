/*
 * FlyncDaemon implementation.
 * Bridges FLYNC PDU transport to BridgeVehicleHardware via IPC socket.
 * DO NOT EDIT -- generated by vhal-gen.
 */

#include "FlyncDaemon.h"
#include "UdpTransport.h"
#include "MockTransport.h"

#include <android-base/logging.h>
#include <sys/socket.h>
#include <sys/un.h>
#include <unistd.h>
#include <getopt.h>

#include <algorithm>
#include <cerrno>
#include <chrono>
#include <cstring>
#include <memory>
#include <thread>

#define LOG_TAG "FlyncDaemon"

namespace flync {

// ---------------------------------------------------------------------------
// Generated signal table
// ---------------------------------------------------------------------------

const SignalDescriptor kSignalTable[] = {
{% for sig in signal_entries %}
    {
        .property_id = static_cast<int32_t>({{ sig.property_id_hex }}),
        .area_id     = {{ sig.area_id }},
        .pdu_id      = {{ sig.pdu_id }},
        .start_bit   = {{ sig.start_bit }},
        .bit_length  = {{ sig.bit_length }},
        .bitmask     = {{ sig.bitmask }},
        .is_rx       = {{ "true" if sig.is_rx else "false" }},
        .signal_name = "{{ sig.signal_name }}",
{% if sig.bit_length == 1 %}
        .value_type  = IpcValueType::BOOLEAN,
{% else %}
        .value_type  = IpcValueType::INT32,
{% endif %}
    },
{% endfor %}
};

const size_t kSignalTableSize = sizeof(kSignalTable) / sizeof(kSignalTable[0]);

// ---------------------------------------------------------------------------
// PDU table (for TX buffer sizing)
// ---------------------------------------------------------------------------

struct PduDescriptor {
    uint32_t pdu_id;
    uint32_t length;
    const char* name;
};

static const PduDescriptor kPduTable[] = {
{% for pdu in pdu_entries %}
    { .pdu_id = {{ pdu.pdu_id }}, .length = {{ pdu.length }}, .name = "{{ pdu.name }}" },
{% endfor %}
};

static const size_t kPduTableSize = sizeof(kPduTable) / sizeof(kPduTable[0]);

// ---------------------------------------------------------------------------
// Construction / destruction
// ---------------------------------------------------------------------------

FlyncDaemon::FlyncDaemon(std::unique_ptr<ITransport> transport)
    : mTransport(std::move(transport)) {}

FlyncDaemon::~FlyncDaemon() {
    stop();
}

// ---------------------------------------------------------------------------
// Lifecycle
// ---------------------------------------------------------------------------

bool FlyncDaemon::start() {
    if (!mTransport->init()) {
        LOG(ERROR) << LOG_TAG << ": Transport init failed";
        return false;
    }

    connectToBridge();
    if (mBridgeFd < 0) {
        LOG(ERROR) << LOG_TAG << ": Cannot connect to bridge socket";
        return false;
    }

    mRunning = true;
    mTransportRxThread = std::thread(&FlyncDaemon::rxLoop, this);
    mBridgeRxThread = std::thread(&FlyncDaemon::bridgeRxLoop, this);

    LOG(INFO) << LOG_TAG << ": Daemon started with " << kSignalTableSize << " signals";
    return true;
}

void FlyncDaemon::stop() {
    mRunning = false;
    mTransport->shutdown();

    if (mTransportRxThread.joinable()) {
        mTransportRxThread.join();
    }
    if (mBridgeRxThread.joinable()) {
        mBridgeRxThread.join();
    }
    if (mBridgeFd >= 0) {
        close(mBridgeFd);
        mBridgeFd = -1;
    }
    LOG(INFO) << LOG_TAG << ": Daemon stopped";
}

void FlyncDaemon::run() {
    // Block until stopped (e.g. by signal handler).
    while (mRunning) {
        std::this_thread::sleep_for(std::chrono::milliseconds(500));
    }
}

// ---------------------------------------------------------------------------
// Bridge socket connection
// ---------------------------------------------------------------------------

void FlyncDaemon::connectToBridge() {
    mBridgeFd = socket(AF_UNIX, SOCK_STREAM, 0);
    if (mBridgeFd < 0) {
        LOG(ERROR) << LOG_TAG << ": socket() failed: " << strerror(errno);
        return;
    }

    struct sockaddr_un addr{};
    addr.sun_family = AF_UNIX;
    strncpy(addr.sun_path, BRIDGE_SOCKET_PATH, sizeof(addr.sun_path) - 1);

    // Retry connection up to 30 times (bridge may not be ready yet).
    for (int attempt = 0; attempt < 30; ++attempt) {
        if (connect(mBridgeFd, reinterpret_cast<struct sockaddr*>(&addr), sizeof(addr)) == 0) {
            LOG(INFO) << LOG_TAG << ": Connected to bridge socket";
            return;
        }
        LOG(WARNING) << LOG_TAG << ": connect() attempt " << (attempt + 1)
                     << " failed: " << strerror(errno) << " -- retrying";
        std::this_thread::sleep_for(std::chrono::seconds(1));
    }

    LOG(ERROR) << LOG_TAG << ": Could not connect to bridge after 30 attempts";
    close(mBridgeFd);
    mBridgeFd = -1;
}

// ---------------------------------------------------------------------------
// IPC send / receive helpers
// ---------------------------------------------------------------------------

bool FlyncDaemon::sendIpcMessage(const IpcMessage* msg, size_t totalLen) {
    if (mBridgeFd < 0) return false;

    ssize_t sent = 0;
    const uint8_t* ptr = reinterpret_cast<const uint8_t*>(msg);
    while (sent < static_cast<ssize_t>(totalLen)) {
        ssize_t n = write(mBridgeFd, ptr + sent, totalLen - sent);
        if (n <= 0) {
            LOG(ERROR) << LOG_TAG << ": write() to bridge failed: " << strerror(errno);
            return false;
        }
        sent += n;
    }
    return true;
}

bool FlyncDaemon::recvIpcMessage(std::vector<uint8_t>& buffer) {
    buffer.resize(IPC_HEADER_SIZE);
    ssize_t nread = 0;
    while (nread < static_cast<ssize_t>(IPC_HEADER_SIZE)) {
        ssize_t n = read(mBridgeFd, buffer.data() + nread, IPC_HEADER_SIZE - nread);
        if (n <= 0) {
            if (n == 0) {
                LOG(WARNING) << LOG_TAG << ": Bridge disconnected";
            } else {
                LOG(ERROR) << LOG_TAG << ": read() header failed: " << strerror(errno);
            }
            return false;
        }
        nread += n;
    }

    const auto* hdr = reinterpret_cast<const IpcMessage*>(buffer.data());
    uint32_t valueLen = hdr->value_len;
    if (valueLen > 0) {
        buffer.resize(IPC_HEADER_SIZE + valueLen);
        nread = 0;
        while (nread < static_cast<ssize_t>(valueLen)) {
            ssize_t n = read(mBridgeFd, buffer.data() + IPC_HEADER_SIZE + nread,
                             valueLen - nread);
            if (n <= 0) {
                LOG(ERROR) << LOG_TAG << ": read() payload failed: " << strerror(errno);
                return false;
            }
            nread += n;
        }
    }
    return true;
}

// ---------------------------------------------------------------------------
// Bit extraction / packing
// ---------------------------------------------------------------------------

uint32_t FlyncDaemon::extractBits(const uint8_t* data, uint32_t startBit,
                                   uint32_t bitLen) const {
    uint32_t result = 0;
    for (uint32_t i = 0; i < bitLen; ++i) {
        uint32_t bitPos = startBit + i;
        uint32_t byteIdx = bitPos / 8;
        uint32_t bitIdx = bitPos % 8;
        if (data[byteIdx] & (1u << bitIdx)) {
            result |= (1u << i);
        }
    }
    return result;
}

void FlyncDaemon::packBits(uint8_t* data, uint32_t startBit, uint32_t bitLen,
                            uint32_t value) {
    for (uint32_t i = 0; i < bitLen; ++i) {
        uint32_t bitPos = startBit + i;
        uint32_t byteIdx = bitPos / 8;
        uint32_t bitIdx = bitPos % 8;
        if (value & (1u << i)) {
            data[byteIdx] |= (1u << bitIdx);
        } else {
            data[byteIdx] &= ~(1u << bitIdx);
        }
    }
}

// ---------------------------------------------------------------------------
// Transport RX loop -- receive PDUs from vehicle bus, unpack signals,
// and push PROPERTY_CHANGED to bridge.
// ---------------------------------------------------------------------------

void FlyncDaemon::rxLoop() {
    LOG(INFO) << LOG_TAG << ": Transport RX thread started";
    uint8_t pduBuf[256];

    while (mRunning) {
        uint32_t pduId = 0;
        int bytesRead = mTransport->receivePdu(pduId, pduBuf, sizeof(pduBuf));
        if (bytesRead <= 0) {
            if (!mRunning) break;
            // Timeout or error -- continue polling.
            continue;
        }

        // For each signal that belongs to this PDU and is RX, extract and send.
        for (size_t i = 0; i < kSignalTableSize; ++i) {
            const auto& sig = kSignalTable[i];
            if (sig.pdu_id != pduId || !sig.is_rx) continue;

            // Ensure we have enough data.
            uint32_t neededBytes = (sig.start_bit + sig.bit_length + 7) / 8;
            if (neededBytes > static_cast<uint32_t>(bytesRead)) {
                LOG(WARNING) << LOG_TAG << ": PDU 0x" << std::hex << pduId
                             << " too short for signal " << sig.signal_name;
                continue;
            }

            uint32_t rawValue = extractBits(pduBuf, sig.start_bit, sig.bit_length);
            rawValue &= sig.bitmask;

            // Cache the raw value.
            {
                std::lock_guard<std::mutex> lock(mCacheMutex);
                mCachedValues[{sig.property_id, sig.area_id}] = rawValue;
            }

            sendPropertyChanged(sig, rawValue);
        }
    }
    LOG(INFO) << LOG_TAG << ": Transport RX thread exited";
}

// ---------------------------------------------------------------------------
// Bridge RX loop -- receive GET/SET from BridgeVehicleHardware
// ---------------------------------------------------------------------------

void FlyncDaemon::bridgeRxLoop() {
    LOG(INFO) << LOG_TAG << ": Bridge RX thread started";

    while (mRunning) {
        std::vector<uint8_t> buffer;
        if (!recvIpcMessage(buffer)) {
            LOG(WARNING) << LOG_TAG << ": Bridge RX: connection lost, exiting";
            mRunning = false;
            break;
        }

        const auto* msg = reinterpret_cast<const IpcMessage*>(buffer.data());
        handleBridgeMessage(msg, buffer.size());
    }
    LOG(INFO) << LOG_TAG << ": Bridge RX thread exited";
}

void FlyncDaemon::handleBridgeMessage(const IpcMessage* msg, size_t totalLen) {
    switch (msg->msg_type) {
        case IpcMsgType::GET_PROPERTY:
            handleGetProperty(msg);
            break;
        case IpcMsgType::SET_PROPERTY:
            handleSetProperty(msg, totalLen);
            break;
        default:
            LOG(WARNING) << LOG_TAG << ": Unknown IPC message type: "
                         << static_cast<uint32_t>(msg->msg_type);
            break;
    }
}

// ---------------------------------------------------------------------------
// GET_PROPERTY -- return cached value
// ---------------------------------------------------------------------------

void FlyncDaemon::handleGetProperty(const IpcMessage* msg) {
    uint32_t cachedRaw = 0;
    IpcValueType vtype = IpcValueType::INT32;

    // Find the signal descriptor for this property.
    const SignalDescriptor* found = nullptr;
    for (size_t i = 0; i < kSignalTableSize; ++i) {
        if (kSignalTable[i].property_id == msg->property_id &&
            kSignalTable[i].area_id == msg->area_id) {
            found = &kSignalTable[i];
            break;
        }
    }

    if (found) {
        vtype = found->value_type;
        std::lock_guard<std::mutex> lock(mCacheMutex);
        auto it = mCachedValues.find({msg->property_id, msg->area_id});
        if (it != mCachedValues.end()) {
            cachedRaw = it->second;
        }
    }

    // Build PROPERTY_RESPONSE.
    size_t payloadLen = sizeof(int32_t);
    size_t totalLen = IPC_HEADER_SIZE + payloadLen;
    std::vector<uint8_t> buf(totalLen, 0);
    auto* resp = reinterpret_cast<IpcMessage*>(buf.data());
    resp->msg_type = IpcMsgType::PROPERTY_RESPONSE;
    resp->property_id = msg->property_id;
    resp->area_id = msg->area_id;
    resp->value_type = vtype;
    resp->value_len = static_cast<uint32_t>(payloadLen);

    int32_t val = static_cast<int32_t>(cachedRaw);
    memcpy(resp->value, &val, sizeof(int32_t));

    sendIpcMessage(resp, totalLen);
}

// ---------------------------------------------------------------------------
// SET_PROPERTY -- pack signal into PDU and send via transport
// ---------------------------------------------------------------------------

void FlyncDaemon::handleSetProperty(const IpcMessage* msg, size_t totalLen) {
    // Find the signal descriptor.
    const SignalDescriptor* found = nullptr;
    for (size_t i = 0; i < kSignalTableSize; ++i) {
        if (kSignalTable[i].property_id == msg->property_id &&
            kSignalTable[i].area_id == msg->area_id) {
            found = &kSignalTable[i];
            break;
        }
    }

    if (!found) {
        LOG(WARNING) << LOG_TAG << ": SET_PROPERTY for unknown prop=0x"
                     << std::hex << msg->property_id;
        return;
    }

    if (found->is_rx) {
        LOG(WARNING) << LOG_TAG << ": Attempted SET on RX signal " << found->signal_name;
        return;
    }

    // Extract the value from the IPC message.
    uint32_t rawValue = 0;
    if (msg->value_len >= sizeof(int32_t)) {
        int32_t val;
        memcpy(&val, msg->value, sizeof(int32_t));
        rawValue = static_cast<uint32_t>(val);
    }

    // Find the PDU length.
    uint32_t pduLen = 0;
    for (size_t i = 0; i < kPduTableSize; ++i) {
        if (kPduTable[i].pdu_id == found->pdu_id) {
            pduLen = kPduTable[i].length;
            break;
        }
    }
    if (pduLen == 0) {
        LOG(ERROR) << LOG_TAG << ": Unknown PDU id=0x" << std::hex << found->pdu_id;
        return;
    }

    // Build PDU buffer with this signal packed.
    std::vector<uint8_t> pduBuf(pduLen, 0);
    packBits(pduBuf.data(), found->start_bit, found->bit_length, rawValue & found->bitmask);

    // Cache the value.
    {
        std::lock_guard<std::mutex> lock(mCacheMutex);
        mCachedValues[{msg->property_id, msg->area_id}] = rawValue;
    }

    int sent = mTransport->sendPdu(found->pdu_id, pduBuf.data(), pduLen);
    if (sent < 0) {
        LOG(ERROR) << LOG_TAG << ": Failed to send PDU for signal " << found->signal_name;
    } else {
        LOG(INFO) << LOG_TAG << ": TX signal " << found->signal_name
                  << " value=" << rawValue << " via PDU 0x" << std::hex << found->pdu_id;
    }
}

// ---------------------------------------------------------------------------
// Send PROPERTY_CHANGED to bridge
// ---------------------------------------------------------------------------

void FlyncDaemon::sendPropertyChanged(const SignalDescriptor& sig, uint32_t rawValue) {
    size_t payloadLen = sizeof(int32_t);
    size_t totalLen = IPC_HEADER_SIZE + payloadLen;
    std::vector<uint8_t> buf(totalLen, 0);
    auto* msg = reinterpret_cast<IpcMessage*>(buf.data());
    msg->msg_type = IpcMsgType::PROPERTY_CHANGED;
    msg->property_id = sig.property_id;
    msg->area_id = sig.area_id;
    msg->value_type = sig.value_type;
    msg->value_len = static_cast<uint32_t>(payloadLen);

    int32_t val = static_cast<int32_t>(rawValue);
    memcpy(msg->value, &val, sizeof(int32_t));

    if (!sendIpcMessage(msg, totalLen)) {
        LOG(ERROR) << LOG_TAG << ": Failed to send PROPERTY_CHANGED for " << sig.signal_name;
    }
}

}  // namespace flync

// ---------------------------------------------------------------------------
// main()
// ---------------------------------------------------------------------------

static void printUsage(const char* progName) {
    fprintf(stderr, "Usage: %s [--mock | --udp]\n", progName);
    fprintf(stderr, "  --mock   Use mock transport with cycling test values\n");
    fprintf(stderr, "  --udp    Use UDP transport for live vehicle bus\n");
}

int main(int argc, char* argv[]) {
    android::base::InitLogging(argv, android::base::LogdLogger());

    enum TransportMode { MOCK, UDP };
    TransportMode mode = MOCK;

    static struct option longOpts[] = {
        {"mock", no_argument, nullptr, 'm'},
        {"udp",  no_argument, nullptr, 'u'},
        {"help", no_argument, nullptr, 'h'},
        {nullptr, 0, nullptr, 0},
    };

    int opt;
    while ((opt = getopt_long(argc, argv, "muh", longOpts, nullptr)) != -1) {
        switch (opt) {
            case 'm': mode = MOCK; break;
            case 'u': mode = UDP;  break;
            case 'h':
            default:
                printUsage(argv[0]);
                return (opt == 'h') ? 0 : 1;
        }
    }

    std::unique_ptr<flync::ITransport> transport;
    if (mode == UDP) {
        LOG(INFO) << "FlyncDaemon: Using UDP transport";
        transport = std::make_unique<flync::UdpTransport>();
    } else {
        LOG(INFO) << "FlyncDaemon: Using Mock transport";
        transport = std::make_unique<flync::MockTransport>();
    }

    flync::FlyncDaemon daemon(std::move(transport));
    if (!daemon.start()) {
        LOG(ERROR) << "FlyncDaemon: Failed to start";
        return 1;
    }

    LOG(INFO) << "FlyncDaemon: Running";
    daemon.run();

    LOG(INFO) << "FlyncDaemon: Exiting";
    return 0;
}
