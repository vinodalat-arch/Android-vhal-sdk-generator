/*
 * FlyncDaemon implementation.
 * Bridges Vehicle Body SDK signals to BridgeVehicleHardware via IPC socket.
 * Calls SDK get_*() / set_*() instead of custom bit manipulation.
 * DO NOT EDIT -- generated by vhal-gen.
 */

#include "FlyncDaemon.h"

// Vehicle Body SDK signal APIs
#include "Read_App_Signal_Data.h"
#include "Write_App_Signal_Data.h"

#include <android-base/logging.h>
#include <unistd.h>

#include <cerrno>
#include <chrono>
#include <cstring>
#include <thread>
#include <vector>

#define LOG_TAG "FlyncDaemon"

namespace flync {

// ---------------------------------------------------------------------------
// Generated signal table
// ---------------------------------------------------------------------------

const SignalBinding kSignalTable[] = {
{% for sig in signal_entries %}
    {
        .property_id = static_cast<int32_t>({{ sig.property_id_hex }}),
        .area_id     = {{ sig.area_id }},
        .is_rx       = {{ "true" if sig.is_rx else "false" }},
        .signal_name = "{{ sig.signal_name }}",
{% if sig.bit_length == 1 %}
        .value_type  = IpcValueType::BOOLEAN,
{% else %}
        .value_type  = IpcValueType::INT32,
{% endif %}
    },
{% endfor %}
};

const size_t kSignalTableSize = sizeof(kSignalTable) / sizeof(kSignalTable[0]);

// ---------------------------------------------------------------------------
// SDK signal dispatchers (generated)
// ---------------------------------------------------------------------------

int32_t pollRxSignal(size_t idx) {
    switch (idx) {
{% set rx_idx = namespace(n=0) %}
{% for sig in signal_entries %}
{% if sig.is_rx and sig.sdk_getter %}
        case {{ rx_idx.n }}: return static_cast<int32_t>({{ sig.sdk_getter }}());
{% set rx_idx.n = rx_idx.n + 1 %}
{% endif %}
{% endfor %}
    }
    return 0;
}

void writeTxSignal(size_t idx, int32_t value) {
    switch (idx) {
{% set tx_idx = namespace(n=0) %}
{% for sig in signal_entries %}
{% if not sig.is_rx and sig.sdk_setter %}
        case {{ tx_idx.n }}: {{ sig.sdk_setter }}(static_cast<uint8_t>(value)); break;
{% set tx_idx.n = tx_idx.n + 1 %}
{% endif %}
{% endfor %}
    }
}

// ---------------------------------------------------------------------------
// Construction / destruction
// ---------------------------------------------------------------------------

FlyncDaemon::FlyncDaemon(int bridgeFd) : mBridgeFd(bridgeFd) {}

FlyncDaemon::~FlyncDaemon() {
    stop();
}

// ---------------------------------------------------------------------------
// Lifecycle
// ---------------------------------------------------------------------------

bool FlyncDaemon::start() {
    if (mBridgeFd < 0) {
        LOG(ERROR) << LOG_TAG << ": Invalid bridge FD";
        return false;
    }

    mRunning = true;
    mRxPollThread = std::thread(&FlyncDaemon::rxPollLoop, this);
    mBridgeRxThread = std::thread(&FlyncDaemon::bridgeRxLoop, this);

    LOG(INFO) << LOG_TAG << ": Daemon started with " << kSignalTableSize << " signals (SDK mode)";
    return true;
}

void FlyncDaemon::stop() {
    mRunning = false;

    if (mRxPollThread.joinable()) {
        mRxPollThread.join();
    }
    if (mBridgeRxThread.joinable()) {
        mBridgeRxThread.join();
    }
    if (mBridgeFd >= 0) {
        close(mBridgeFd);
        mBridgeFd = -1;
    }
    LOG(INFO) << LOG_TAG << ": Daemon stopped";
}

void FlyncDaemon::run() {
    // Block until stopped (e.g. by signal handler).
    while (mRunning) {
        std::this_thread::sleep_for(std::chrono::milliseconds(500));
    }
}

// ---------------------------------------------------------------------------
// IPC send / receive helpers
// ---------------------------------------------------------------------------

bool FlyncDaemon::sendIpcMessage(const IpcMessage* msg, size_t totalLen) {
    if (mBridgeFd < 0) return false;

    ssize_t sent = 0;
    const uint8_t* ptr = reinterpret_cast<const uint8_t*>(msg);
    while (sent < static_cast<ssize_t>(totalLen)) {
        ssize_t n = write(mBridgeFd, ptr + sent, totalLen - sent);
        if (n <= 0) {
            LOG(ERROR) << LOG_TAG << ": write() to bridge failed: " << strerror(errno);
            return false;
        }
        sent += n;
    }
    return true;
}

bool FlyncDaemon::recvIpcMessage(std::vector<uint8_t>& buffer) {
    buffer.resize(IPC_HEADER_SIZE);
    ssize_t nread = 0;
    while (nread < static_cast<ssize_t>(IPC_HEADER_SIZE)) {
        ssize_t n = read(mBridgeFd, buffer.data() + nread, IPC_HEADER_SIZE - nread);
        if (n <= 0) {
            if (n == 0) {
                LOG(WARNING) << LOG_TAG << ": Bridge disconnected";
            } else {
                LOG(ERROR) << LOG_TAG << ": read() header failed: " << strerror(errno);
            }
            return false;
        }
        nread += n;
    }

    const auto* hdr = reinterpret_cast<const IpcMessage*>(buffer.data());
    uint32_t valueLen = hdr->value_len;
    if (valueLen > 0) {
        buffer.resize(IPC_HEADER_SIZE + valueLen);
        nread = 0;
        while (nread < static_cast<ssize_t>(valueLen)) {
            ssize_t n = read(mBridgeFd, buffer.data() + IPC_HEADER_SIZE + nread,
                             valueLen - nread);
            if (n <= 0) {
                LOG(ERROR) << LOG_TAG << ": read() payload failed: " << strerror(errno);
                return false;
            }
            nread += n;
        }
    }
    return true;
}

// ---------------------------------------------------------------------------
// RX poll loop -- periodically call SDK get_*() for each RX signal,
// detect changes, and push PROPERTY_CHANGED to bridge.
// ---------------------------------------------------------------------------

void FlyncDaemon::rxPollLoop() {
    LOG(INFO) << LOG_TAG << ": RX poll thread started (SDK mode)";

    while (mRunning) {
        // Poll SDK getters for each RX signal.
        size_t rxIdx = 0;
        for (size_t i = 0; i < kSignalTableSize; ++i) {
            const auto& sig = kSignalTable[i];
            if (!sig.is_rx) continue;

            int32_t currentValue = pollRxSignal(rxIdx);
            ++rxIdx;

            // Check for change against cached value.
            bool changed = false;
            {
                std::lock_guard<std::mutex> lock(mCacheMutex);
                auto key = std::make_pair(sig.property_id, sig.area_id);
                auto it = mCachedValues.find(key);
                if (it == mCachedValues.end() || it->second != currentValue) {
                    mCachedValues[key] = currentValue;
                    changed = true;
                }
            }

            if (changed) {
                sendPropertyChanged(sig, currentValue);
            }
        }

        // Poll interval -- the SDK's COM layer updates its buffers
        // asynchronously; we sample at ~50 Hz.
        std::this_thread::sleep_for(std::chrono::milliseconds(20));
    }
    LOG(INFO) << LOG_TAG << ": RX poll thread exited";
}

// ---------------------------------------------------------------------------
// Bridge RX loop -- receive GET/SET from BridgeVehicleHardware
// ---------------------------------------------------------------------------

void FlyncDaemon::bridgeRxLoop() {
    LOG(INFO) << LOG_TAG << ": Bridge RX thread started";

    while (mRunning) {
        std::vector<uint8_t> buffer;
        if (!recvIpcMessage(buffer)) {
            LOG(WARNING) << LOG_TAG << ": Bridge RX: connection lost, exiting";
            mRunning = false;
            break;
        }

        const auto* msg = reinterpret_cast<const IpcMessage*>(buffer.data());
        handleBridgeMessage(msg, buffer.size());
    }
    LOG(INFO) << LOG_TAG << ": Bridge RX thread exited";
}

void FlyncDaemon::handleBridgeMessage(const IpcMessage* msg, size_t totalLen) {
    switch (msg->msg_type) {
        case IpcMsgType::GET_PROPERTY:
            handleGetProperty(msg);
            break;
        case IpcMsgType::SET_PROPERTY:
            handleSetProperty(msg, totalLen);
            break;
        default:
            LOG(WARNING) << LOG_TAG << ": Unknown IPC message type: "
                         << static_cast<uint32_t>(msg->msg_type);
            break;
    }
}

// ---------------------------------------------------------------------------
// GET_PROPERTY -- return cached value
// ---------------------------------------------------------------------------

void FlyncDaemon::handleGetProperty(const IpcMessage* msg) {
    int32_t cachedRaw = 0;
    IpcValueType vtype = IpcValueType::INT32;

    // Find the signal binding for this property.
    const SignalBinding* found = nullptr;
    for (size_t i = 0; i < kSignalTableSize; ++i) {
        if (kSignalTable[i].property_id == msg->property_id &&
            kSignalTable[i].area_id == msg->area_id) {
            found = &kSignalTable[i];
            break;
        }
    }

    if (found) {
        vtype = found->value_type;
        std::lock_guard<std::mutex> lock(mCacheMutex);
        auto it = mCachedValues.find({msg->property_id, msg->area_id});
        if (it != mCachedValues.end()) {
            cachedRaw = it->second;
        }
    }

    // Build PROPERTY_RESPONSE.
    size_t payloadLen = sizeof(int32_t);
    size_t totalLen = IPC_HEADER_SIZE + payloadLen;
    std::vector<uint8_t> buf(totalLen, 0);
    auto* resp = reinterpret_cast<IpcMessage*>(buf.data());
    resp->msg_type = IpcMsgType::PROPERTY_RESPONSE;
    resp->property_id = msg->property_id;
    resp->area_id = msg->area_id;
    resp->value_type = vtype;
    resp->value_len = static_cast<uint32_t>(payloadLen);

    int32_t val = cachedRaw;
    memcpy(resp->value, &val, sizeof(int32_t));

    sendIpcMessage(resp, totalLen);
}

// ---------------------------------------------------------------------------
// SET_PROPERTY -- call SDK set_*() for the matching TX signal
// ---------------------------------------------------------------------------

void FlyncDaemon::handleSetProperty(const IpcMessage* msg, size_t totalLen) {
    // Find the signal binding and its TX index.
    const SignalBinding* found = nullptr;
    size_t txIdx = 0;
    size_t txCounter = 0;
    for (size_t i = 0; i < kSignalTableSize; ++i) {
        if (!kSignalTable[i].is_rx) {
            if (kSignalTable[i].property_id == msg->property_id &&
                kSignalTable[i].area_id == msg->area_id) {
                found = &kSignalTable[i];
                txIdx = txCounter;
            }
            ++txCounter;
        }
    }

    if (!found) {
        LOG(WARNING) << LOG_TAG << ": SET_PROPERTY for unknown prop=0x"
                     << std::hex << msg->property_id;
        return;
    }

    if (found->is_rx) {
        LOG(WARNING) << LOG_TAG << ": Attempted SET on RX signal " << found->signal_name;
        return;
    }

    // Extract the value from the IPC message.
    int32_t rawValue = 0;
    if (msg->value_len >= sizeof(int32_t)) {
        memcpy(&rawValue, msg->value, sizeof(int32_t));
    }

    // Call the SDK setter via the generated dispatcher.
    writeTxSignal(txIdx, rawValue);

    // Cache the value.
    {
        std::lock_guard<std::mutex> lock(mCacheMutex);
        mCachedValues[{msg->property_id, msg->area_id}] = rawValue;
    }

    LOG(INFO) << LOG_TAG << ": TX signal " << found->signal_name
              << " value=" << rawValue << " via SDK setter";
}

// ---------------------------------------------------------------------------
// Send PROPERTY_CHANGED to bridge
// ---------------------------------------------------------------------------

void FlyncDaemon::sendPropertyChanged(const SignalBinding& sig, int32_t value) {
    size_t payloadLen = sizeof(int32_t);
    size_t totalLen = IPC_HEADER_SIZE + payloadLen;
    std::vector<uint8_t> buf(totalLen, 0);
    auto* msg = reinterpret_cast<IpcMessage*>(buf.data());
    msg->msg_type = IpcMsgType::PROPERTY_CHANGED;
    msg->property_id = sig.property_id;
    msg->area_id = sig.area_id;
    msg->value_type = sig.value_type;
    msg->value_len = static_cast<uint32_t>(payloadLen);

    int32_t val = value;
    memcpy(msg->value, &val, sizeof(int32_t));

    if (!sendIpcMessage(msg, totalLen)) {
        LOG(ERROR) << LOG_TAG << ": Failed to send PROPERTY_CHANGED for " << sig.signal_name;
    }
}

}  // namespace flync

// ---------------------------------------------------------------------------
// main()
// ---------------------------------------------------------------------------

int main(int argc, char* argv[]) {
    android::base::InitLogging(argv, android::base::LogdLogger());

    LOG(INFO) << "FlyncDaemon: Starting (SDK mode, child process)";

    // BridgeVehicleHardware passes the socketpair FD via dup2() to STDIN.
    int bridgeFd = STDIN_FILENO;

    flync::FlyncDaemon daemon(bridgeFd);
    if (!daemon.start()) {
        LOG(ERROR) << "FlyncDaemon: Failed to start";
        return 1;
    }

    LOG(INFO) << "FlyncDaemon: Running";
    daemon.run();

    LOG(INFO) << "FlyncDaemon: Exiting";
    return 0;
}
